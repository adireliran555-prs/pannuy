generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String    @id @default(uuid())
  phone          String    @unique
  name           String
  email          String?
  weddingDate    DateTime?
  weddingArea    String?
  weddingAreaLat Float?
  weddingAreaLng Float?
  sessionToken   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  meetings      Meeting[]       @relation("CustomerMeetings")
  saved         SavedSupplier[]
  reviews       Review[]
  notifications Notification[]
  profileViews  ProfileView[]
  referrals     Referral[]
  events        Event[]
}

model Otp {
  id        String   @id @default(uuid())
  phone     String
  hash      String
  expiresAt DateTime
  used      Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([phone])
}

model Supplier {
  id                  String             @id @default(uuid())
  slug                String             @unique
  name                String
  phone               String             @unique
  email               String?
  category            Category           @default(PHOTOGRAPHER)
  bioHe               String?            @db.Text
  city                String?
  serviceAreas        String[]
  supportedEventTypes String[]           @default(["wedding"])
  basePriceFrom       Int?
  basePriceTo         Int?
  ratingAvg           Float              @default(0)
  ratingCount         Int                @default(0)
  isVerified          Boolean            @default(false)
  isActive            Boolean            @default(false)
  googleCalendarId    String?
  googleRefreshToken  String?
  googleAccessToken   String?
  googleTokenExpiry   DateTime?
  responseRate        Float?
  sessionToken        String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  affiliateCode       String?            @unique
  warningCount        Int                @default(0)
  subscriptionStatus  SubscriptionStatus @default(INACTIVE)
  subscriptionStartAt DateTime?
  highlights          String[] // admin-curated praise points (replaces star reviews)
  googleChannelId     String? // Google Calendar push-notification channel
  googleChannelToken  String? // secret token validated on webhook calls
  googleResourceId    String?
  googleChannelExpiry DateTime?

  photos             SupplierPhoto[]
  packages           SupplierPackage[]
  availability       AvailabilitySlot[]
  meetings           Meeting[]              @relation("SupplierMeetings")
  reviews            Review[]
  savedBy            SavedSupplier[]
  notifications      Notification[]
  profileViews       ProfileView[]
  earningsAsReferrer AffiliateEarning[]     @relation("EarningsAsReferrer")
  earningsAsReceiver AffiliateEarning[]     @relation("EarningsAsReceiver")
  warnings           SupplierWarning[]
  payments           PaymentTransaction[]
  payoutRequests     PayoutRequest[]
  referrals          Referral[]
  planItems          EventPlanItem[]
  relationshipsFrom  SupplierRelationship[] @relation("RelFrom")
  relationshipsTo    SupplierRelationship[] @relation("RelTo")

  @@index([category])
  @@index([isActive, isVerified])
}

model SupplierWarning {
  id         String   @id @default(uuid())
  supplierId String
  reasonHe   String   @db.Text
  createdAt  DateTime @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
}

model PaymentTransaction {
  id          String        @id @default(uuid())
  supplierId  String
  type        PaymentType
  amountIls   Int
  status      PaymentStatus @default(PENDING)
  provider    String? // e.g. "payplus"
  providerRef String? // gateway transaction id
  meetingId   String? // for deposit charges
  note        String?
  createdAt   DateTime      @default(now())
  settledAt   DateTime?

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
  @@index([type, status])
}

model PayoutRequest {
  id          String       @id @default(uuid())
  supplierId  String
  amountIls   Int
  status      PayoutStatus @default(PENDING)
  note        String?
  createdAt   DateTime     @default(now())
  processedAt DateTime?

  supplier Supplier           @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  earnings AffiliateEarning[]

  @@index([supplierId])
  @@index([status])
}

enum PaymentType {
  SUBSCRIPTION
  DEPOSIT
  COMMISSION
  PAYOUT
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

enum PayoutStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
}

enum Category {
  PHOTOGRAPHER
  BRIDAL_SUITE
  VIDEOGRAPHER
  FLORIST
  DJ
  CATERING
  VENUE // אולם/גני אירועים
  HAIR_STYLIST // מסרקות
  MAKEUP_ARTIST // מאפרות
  PHOTO_BOOTH // צלמי מגנטים
  EVENT_PRODUCER // הושבה/מפיקים
}

enum SubscriptionStatus {
  INACTIVE
  ACTIVE
  SUSPENDED
}

model SupplierPhoto {
  id            String    @id @default(uuid())
  supplierId    String
  cloudinaryUrl String
  publicId      String
  type          PhotoType @default(PORTFOLIO)
  sortOrder     Int       @default(0)
  createdAt     DateTime  @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
}

enum PhotoType {
  PROFILE
  COVER
  PORTFOLIO
}

model SupplierPackage {
  id         String   @id @default(uuid())
  supplierId String
  nameHe     String
  descHe     String?  @db.Text
  price      Int
  hours      Int?
  includes   String[]
  isPopular  Boolean  @default(false)
  createdAt  DateTime @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
}

model AvailabilitySlot {
  id            String             @id @default(uuid())
  supplierId    String
  date          DateTime           @db.Date
  startTime     String
  endTime       String
  isBlocked     Boolean            @default(true)
  source        AvailabilitySource @default(MANUAL)
  googleEventId String?
  syncedAt      DateTime           @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([supplierId, date, googleEventId])
  @@index([supplierId, date])
}

enum AvailabilitySource {
  GOOGLE
  MANUAL
}

model Meeting {
  id                   String        @id @default(uuid())
  customerId           String
  supplierId           String
  requestedDate        DateTime      @db.Date
  startTime            String
  endTime              String
  status               MeetingStatus @default(PENDING)
  meetingType          MeetingType   @default(VIDEO)
  customerNotes        String?       @db.Text
  supplierNotes        String?       @db.Text
  googleEventId        String?
  referredBySupplierId String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  customer         User              @relation("CustomerMeetings", fields: [customerId], references: [id])
  supplier         Supplier          @relation("SupplierMeetings", fields: [supplierId], references: [id])
  review           Review?
  affiliateEarning AffiliateEarning?
  referral         Referral?

  @@index([customerId])
  @@index([supplierId])
  @@index([requestedDate])
}

enum MeetingStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
  COMPLETED
}

enum MeetingType {
  VIDEO
  PHONE
  IN_PERSON
}

model Review {
  id         String   @id @default(uuid())
  customerId String
  supplierId String
  meetingId  String   @unique
  rating     Int
  textHe     String?  @db.Text
  photos     String[]
  isVisible  Boolean  @default(true)
  createdAt  DateTime @default(now())

  customer User     @relation(fields: [customerId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])
  meeting  Meeting  @relation(fields: [meetingId], references: [id])

  @@index([supplierId])
}

model AffiliateEarning {
  id                  String          @id @default(uuid())
  referringSupplierId String
  receivingSupplierId String
  meetingId           String          @unique
  amountIls           Int
  status              AffiliateStatus @default(PENDING)
  payoutRequestId     String? // set when claimed by a payout request
  createdAt           DateTime        @default(now())
  paidAt              DateTime?

  referringSupplier Supplier       @relation("EarningsAsReferrer", fields: [referringSupplierId], references: [id])
  receivingSupplier Supplier       @relation("EarningsAsReceiver", fields: [receivingSupplierId], references: [id])
  meeting           Meeting        @relation(fields: [meetingId], references: [id])
  payoutRequest     PayoutRequest? @relation(fields: [payoutRequestId], references: [id])

  @@index([referringSupplierId])
  @@index([receivingSupplierId])
  @@index([payoutRequestId])
}

enum AffiliateStatus {
  PENDING
  CONFIRMED
  PAID
  CANCELLED
}

// Tracks every time the platform connects a customer to a supplier — whether the
// contact happened in-app (a meeting request) or off-platform (WhatsApp). Lets us
// follow up with the customer, escalate to an admin call when there's no reply,
// and know the outcome of every referral we make.
model Referral {
  id                  String          @id @default(uuid())
  customerId          String
  supplierId          String
  channel             ReferralChannel @default(IN_APP)
  status              ReferralStatus  @default(NEW)
  meetingId           String?         @unique // set when the contact was an in-app booking
  customerNotes       String?         @db.Text
  adminNotes          String?         @db.Text
  followUpCount       Int             @default(0)
  lastFollowUpAt      DateTime?
  customerConfirmedAt DateTime? // customer told us whether they connected
  convertedAt         DateTime? // turned into a booking / deal
  closedAt            DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  customer User     @relation(fields: [customerId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])
  meeting  Meeting? @relation(fields: [meetingId], references: [id])

  @@index([supplierId])
  @@index([customerId])
  @@index([status])
  @@index([status, lastFollowUpAt])
}

enum ReferralChannel {
  IN_APP // booked a meeting through the app
  WHATSAPP // opened WhatsApp from the supplier profile
}

enum ReferralStatus {
  NEW // just created, supplier notified
  AWAITING_REPLY // follow-up sent to the customer, waiting for an answer
  CONNECTED // customer confirmed they spoke with the supplier
  NO_ANSWER // no reply after repeated follow-ups → needs an admin call
  CONVERTED // turned into a booking
  LOST // didn't work out
}

model SavedSupplier {
  id         String   @id @default(uuid())
  customerId String
  supplierId String
  createdAt  DateTime @default(now())

  customer User     @relation(fields: [customerId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@unique([customerId, supplierId])
}

model Notification {
  id         String   @id @default(uuid())
  userId     String?
  supplierId String?
  type       String
  titleHe    String
  bodyHe     String
  isRead     Boolean  @default(false)
  metadata   Json?
  createdAt  DateTime @default(now())

  user     User?     @relation(fields: [userId], references: [id])
  supplier Supplier? @relation(fields: [supplierId], references: [id])
}

model ProfileView {
  id         String   @id @default(uuid())
  supplierId String
  customerId String?
  source     String?
  createdAt  DateTime @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  customer User?    @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([supplierId, createdAt])
  @@index([createdAt])
}

// ─── Guided event planning ("plan an event with us" journey) ────────────────

model Event {
  id           String      @id @default(uuid())
  userId       String
  type         String      @default("wedding") // event type id (see lib/event-types)
  date         DateTime?   @db.Date
  dateFlexible Boolean     @default(false)
  areas        String[]
  city         String?
  guestCount   Int?
  budgetMode   BudgetMode  @default(TOTAL)
  budgetAmount Int? // TOTAL: full event budget in ILS. PER_GUEST: ILS per guest.
  vibeTags     String[]
  kosher       Boolean     @default(false)
  status       EventStatus @default(ACTIVE)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items EventPlanItem[]

  @@index([userId, status])
}

model EventPlanItem {
  id                 String         @id @default(uuid())
  eventId            String
  category           Category
  sortOrder          Int            @default(0)
  status             PlanItemStatus @default(PENDING)
  allocatedBudget    Int? // recommended budget for this category (ILS)
  selectedSupplierId String?
  selectedPackageId  String? // SupplierPackage id (no FK; package list is mutable)
  committedPrice     Int? // locked total once selected (per-guest categories = price x guests)
  notes              String?        @db.Text
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  event            Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  selectedSupplier Supplier? @relation(fields: [selectedSupplierId], references: [id], onDelete: SetNull)

  @@unique([eventId, category])
  @@index([eventId])
}

// Placeholder for venue↔supplier (and cross-vendor) relationships. Empty at
// launch; admin populates later. PREFERRED/RECOMMENDED float partners to the
// top; EXCLUSIVE (future) would restrict the offering for that category.
model SupplierRelationship {
  id             String               @id @default(uuid())
  fromSupplierId String
  toSupplierId   String
  category       Category // the category the "to" supplier fills for the "from" supplier
  type           SupplierRelationType @default(PREFERRED)
  createdAt      DateTime             @default(now())

  fromSupplier Supplier @relation("RelFrom", fields: [fromSupplierId], references: [id], onDelete: Cascade)
  toSupplier   Supplier @relation("RelTo", fields: [toSupplierId], references: [id], onDelete: Cascade)

  @@unique([fromSupplierId, toSupplierId])
  @@index([fromSupplierId, category])
}

enum EventStatus {
  ACTIVE
  ARCHIVED
  COMPLETED
}

enum PlanItemStatus {
  PENDING // not started
  BROWSING // opened the category, not yet chosen
  SELECTED // picked a supplier + package
  SKIPPED // deferred for later
  NOT_NEEDED // explicitly not required for this event
}

enum BudgetMode {
  TOTAL
  PER_GUEST
}

enum SupplierRelationType {
  EXCLUSIVE
  PREFERRED
  RECOMMENDED
}
