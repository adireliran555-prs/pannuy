generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String    @id @default(uuid())
  phone           String    @unique
  name            String
  email           String?
  weddingDate     DateTime?
  weddingArea     String?
  weddingAreaLat  Float?
  weddingAreaLng  Float?
  sessionToken    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  meetings      Meeting[]      @relation("CustomerMeetings")
  saved         SavedSupplier[]
  reviews       Review[]
  notifications Notification[]
  profileViews  ProfileView[]
}

model Otp {
  id        String   @id @default(uuid())
  phone     String
  hash      String
  expiresAt DateTime
  used      Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([phone])
}

model Supplier {
  id                   String             @id @default(uuid())
  slug                 String             @unique
  name                 String
  phone                String             @unique
  email                String?
  category             Category           @default(PHOTOGRAPHER)
  bioHe                String?            @db.Text
  city                 String?
  serviceAreas         String[]
  basePriceFrom        Int?
  basePriceTo          Int?
  ratingAvg            Float              @default(0)
  ratingCount          Int                @default(0)
  isVerified           Boolean            @default(false)
  isActive             Boolean            @default(false)
  googleCalendarId     String?
  googleRefreshToken   String?
  googleAccessToken    String?
  googleTokenExpiry    DateTime?
  responseRate         Float?
  sessionToken         String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  affiliateCode        String?            @unique
  warningCount         Int                @default(0)
  subscriptionStatus   SubscriptionStatus @default(INACTIVE)
  subscriptionStartAt  DateTime?
  highlights           String[]           // admin-curated praise points (replaces star reviews)
  googleChannelId      String?            // Google Calendar push-notification channel
  googleChannelToken   String?            // secret token validated on webhook calls
  googleResourceId     String?
  googleChannelExpiry  DateTime?

  photos             SupplierPhoto[]
  packages           SupplierPackage[]
  availability       AvailabilitySlot[]
  meetings           Meeting[]          @relation("SupplierMeetings")
  reviews            Review[]
  savedBy            SavedSupplier[]
  notifications      Notification[]
  profileViews       ProfileView[]
  earningsAsReferrer AffiliateEarning[] @relation("EarningsAsReferrer")
  earningsAsReceiver AffiliateEarning[] @relation("EarningsAsReceiver")
  warnings           SupplierWarning[]
  payments           PaymentTransaction[]
  payoutRequests     PayoutRequest[]

  @@index([category])
  @@index([isActive, isVerified])
}

model SupplierWarning {
  id         String   @id @default(uuid())
  supplierId String
  reasonHe   String   @db.Text
  createdAt  DateTime @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
}

model PaymentTransaction {
  id          String        @id @default(uuid())
  supplierId  String
  type        PaymentType
  amountIls   Int
  status      PaymentStatus @default(PENDING)
  provider    String?       // e.g. "payplus"
  providerRef String?       // gateway transaction id
  meetingId   String?       // for deposit charges
  note        String?
  createdAt   DateTime      @default(now())
  settledAt   DateTime?

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
  @@index([type, status])
}

model PayoutRequest {
  id          String       @id @default(uuid())
  supplierId  String
  amountIls   Int
  status      PayoutStatus @default(PENDING)
  note        String?
  createdAt   DateTime     @default(now())
  processedAt DateTime?

  supplier Supplier           @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  earnings AffiliateEarning[]

  @@index([supplierId])
  @@index([status])
}

enum PaymentType {
  SUBSCRIPTION
  DEPOSIT
  COMMISSION
  PAYOUT
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

enum PayoutStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
}

enum Category {
  PHOTOGRAPHER
  BRIDAL_SUITE
  VIDEOGRAPHER
  FLORIST
  DJ
  CATERING
  VENUE           // אולם/גני אירועים
  HAIR_STYLIST    // מסרקות
  MAKEUP_ARTIST   // מאפרות
  PHOTO_BOOTH     // צלמי מגנטים
  EVENT_PRODUCER  // הושבה/מפיקים
}

enum SubscriptionStatus {
  INACTIVE
  ACTIVE
  SUSPENDED
}

model SupplierPhoto {
  id            String    @id @default(uuid())
  supplierId    String
  cloudinaryUrl String
  publicId      String
  type          PhotoType @default(PORTFOLIO)
  sortOrder     Int       @default(0)
  createdAt     DateTime  @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
}

enum PhotoType {
  PROFILE
  COVER
  PORTFOLIO
}

model SupplierPackage {
  id         String   @id @default(uuid())
  supplierId String
  nameHe     String
  descHe     String?  @db.Text
  price      Int
  hours      Int?
  includes   String[]
  isPopular  Boolean  @default(false)
  createdAt  DateTime @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
}

model AvailabilitySlot {
  id            String             @id @default(uuid())
  supplierId    String
  date          DateTime           @db.Date
  startTime     String
  endTime       String
  isBlocked     Boolean            @default(true)
  source        AvailabilitySource @default(MANUAL)
  googleEventId String?
  syncedAt      DateTime           @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([supplierId, date, googleEventId])
  @@index([supplierId, date])
}

enum AvailabilitySource {
  GOOGLE
  MANUAL
}

model Meeting {
  id                   String        @id @default(uuid())
  customerId           String
  supplierId           String
  requestedDate        DateTime      @db.Date
  startTime            String
  endTime              String
  status               MeetingStatus @default(PENDING)
  meetingType          MeetingType   @default(VIDEO)
  customerNotes        String?       @db.Text
  supplierNotes        String?       @db.Text
  googleEventId        String?
  referredBySupplierId String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  customer         User              @relation("CustomerMeetings", fields: [customerId], references: [id])
  supplier         Supplier          @relation("SupplierMeetings", fields: [supplierId], references: [id])
  review           Review?
  affiliateEarning AffiliateEarning?

  @@index([customerId])
  @@index([supplierId])
  @@index([requestedDate])
}

enum MeetingStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
  COMPLETED
}

enum MeetingType {
  VIDEO
  PHONE
  IN_PERSON
}

model Review {
  id         String   @id @default(uuid())
  customerId String
  supplierId String
  meetingId  String   @unique
  rating     Int
  textHe     String?  @db.Text
  photos     String[]
  isVisible  Boolean  @default(true)
  createdAt  DateTime @default(now())

  customer User     @relation(fields: [customerId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])
  meeting  Meeting  @relation(fields: [meetingId], references: [id])

  @@index([supplierId])
}

model AffiliateEarning {
  id                  String          @id @default(uuid())
  referringSupplierId String
  receivingSupplierId String
  meetingId           String          @unique
  amountIls           Int
  status              AffiliateStatus @default(PENDING)
  payoutRequestId     String?         // set when claimed by a payout request
  createdAt           DateTime        @default(now())
  paidAt              DateTime?

  referringSupplier Supplier       @relation("EarningsAsReferrer", fields: [referringSupplierId], references: [id])
  receivingSupplier Supplier       @relation("EarningsAsReceiver", fields: [receivingSupplierId], references: [id])
  meeting           Meeting        @relation(fields: [meetingId], references: [id])
  payoutRequest     PayoutRequest? @relation(fields: [payoutRequestId], references: [id])

  @@index([referringSupplierId])
  @@index([receivingSupplierId])
  @@index([payoutRequestId])
}

enum AffiliateStatus {
  PENDING
  CONFIRMED
  PAID
  CANCELLED
}

model SavedSupplier {
  id         String   @id @default(uuid())
  customerId String
  supplierId String
  createdAt  DateTime @default(now())

  customer User     @relation(fields: [customerId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@unique([customerId, supplierId])
}

model Notification {
  id         String   @id @default(uuid())
  userId     String?
  supplierId String?
  type       String
  titleHe    String
  bodyHe     String
  isRead     Boolean  @default(false)
  metadata   Json?
  createdAt  DateTime @default(now())

  user     User?     @relation(fields: [userId], references: [id])
  supplier Supplier? @relation(fields: [supplierId], references: [id])
}

model ProfileView {
  id         String   @id @default(uuid())
  supplierId String
  customerId String?
  source     String?
  createdAt  DateTime @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  customer User?    @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([supplierId, createdAt])
  @@index([createdAt])
}
